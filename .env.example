# Hosted web service
HOST=0.0.0.0
PORT=3000
HEISS_DATA=/data
HEISS_PUBLIC_URL=https://app.example.com
HEISS_SESSION_SECRET=replace-with-at-least-32-random-bytes
HEISS_DOWNLOAD_PATH=/data/releases/Heiss-mac-arm64.zip
HEISS_MAX_UPLOAD_MB=2048
# Optional only when hosting a separate browser client; same-origin is the secure default.
HEISS_CORS_ORIGIN=

# Google OAuth (redirect URI: HEISS_PUBLIC_URL/api/auth/google/callback)
HEISS_GOOGLE_CLIENT_ID=
HEISS_GOOGLE_CLIENT_SECRET=

# Passwordless email (Resend)
HEISS_RESEND_API_KEY=
HEISS_EMAIL_FROM=Heiss <login@example.com>

# Lemon Squeezy checkout URLs + webhook
HEISS_CHECKOUT_SOLO=
HEISS_CHECKOUT_RACK=
HEISS_CHECKOUT_SCALE=
HEISS_LEMON_WEBHOOK_SECRET=
HEISS_LEMON_VARIANT_SOLO=
HEISS_LEMON_VARIANT_RACK=
HEISS_LEMON_VARIANT_SCALE=

# Optional JSON override for hot-patched platform UI profiles
HEISS_UI_PROFILES_JSON=
